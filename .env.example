# IPTV Bangladesh IP Filter - Environment Configuration
# Copy this file to .env and configure with your proxy details

# ============================================
# Bangladesh Proxy Configuration
# ============================================

# Enable Bangladesh proxy filtering
USE_BD_PROXY=true

# HTTP Proxy for Bangladesh
# Format: http://ip:port or http://username:password@ip:port
BD_PROXY_HTTP=http://your-bangladesh-proxy:8080

# HTTPS Proxy for Bangladesh
# Format: http://ip:port or http://username:password@ip:port
BD_PROXY_HTTPS=http://your-bangladesh-proxy:8080

# ============================================
# Connection Settings
# ============================================

# Connection timeout in seconds
TIMEOUT=10

# Number of retries for failed connections
RETRY_COUNT=3

# Delay between requests (seconds)
REQUEST_DELAY=0.2

# ============================================
# VPN Configuration (If using VPN instead of Proxy)
# ============================================

# OpenVPN config file path (optional)
# OPENVPN_CONFIG_PATH=/path/to/your-bd.ovpn

# WireGuard config file path (optional)
# WIREGUARD_CONFIG_PATH=/etc/wireguard/wg0.conf

# ============================================
# Filtering Options
# ============================================

# Enable/disable channel availability filtering
FILTER_BY_AVAILABILITY=true

# Exclude specific channel names (comma-separated)
# EXCLUDE_CHANNELS=Sport,PPV,AdultContent

# Include only specific channel names (comma-separated)
# INCLUDE_CHANNELS=

# ============================================
# Output Settings
# ============================================

# Output directory
OUTPUT_DIR=.

# Output filename for merged M3U
OUTPUT_M3U=merged.m3u

# Output filename for sources info
OUTPUT_SOURCES=sources.txt

# ============================================
# Logging
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (optional)
# LOG_FILE=merge.log

# ============================================
# GitHub Actions Configuration
# ============================================

# These are automatically set in GitHub Actions
# But you can override them locally if needed:

# GITHUB_TOKEN=your_github_token
# COMMIT_MESSAGE_PREFIX=🔄 Update IPTV channels -
